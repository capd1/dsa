# Binary Search Tree Implementation in Python

class Node:
    def __init__(self, data):
        self.data = data
        self.left = None
        self.right = None


class BST:
    def __init__(self):
        self.root = None

    # a) Insert
    def insert(self, root, data):
        if root is None:
            return Node(data)

        if data < root.data:
            root.left = self.insert(root.left, data)
        else:
            root.right = self.insert(root.right, data)

        return root

    # b) Search
    def search(self, root, key):
        if root is None:
            return False

        if root.data == key:
            return True

        if key < root.data:
            return self.search(root.left, key)
        else:
            return self.search(root.right, key)

    # c) Display Leaf Nodes
    def display_leaf_nodes(self, root):
        if root is not None:
            if root.left is None and root.right is None:
                print(root.data, end=" ")

            self.display_leaf_nodes(root.left)
            self.display_leaf_nodes(root.right)

    # d) Level Wise Traversal
    def level_order(self):
        if self.root is None:
            return

        queue = []
        queue.append(self.root)

        while queue:
            current = queue.pop(0)
            print(current.data, end=" ")

            if current.left:
                queue.append(current.left)

            if current.right:
                queue.append(current.right)


# Driver Code
bst = BST()

n = int(input("Enter number of nodes: "))

for i in range(n):
    value = int(input("Enter value: "))
    bst.root = bst.insert(bst.root, value)

# Search Operation
key = int(input("Enter element to search: "))

if bst.search(bst.root, key):
    print("Element found")
else:
    print("Element not found")

# Display Leaf Nodes
print("Leaf Nodes are:")
bst.display_leaf_nodes(bst.root)

# Level Wise Traversal
print("\nLevel Order Traversal:")
bst.level_order()
